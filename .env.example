# ================= AZERII — environment (Variant В: everything in Supabase) =================
# .env is gitignored. Fill these locally and mirror them in Vercel → Settings → Environment Variables.

# Secret used to sign Payload auth tokens. Use a long random string.
# Generate one:  openssl rand -base64 32
PAYLOAD_SECRET=change-me-to-a-long-random-string

# ---- Supabase Postgres (products live here) ----
# Supabase → Project Settings → Database → Connection string → URI (Transaction pooler, port 6543).
# Use 6543, NOT the session pooler on 5432: session mode caps the whole project
# (production + local dev) at 15 clients and serverless exhausts that.
# Do NOT append ?sslmode=require — it overrides the adapter's TLS settings and the
# connection fails. TLS is still used. Example:
# DATABASE_URI=postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres
DATABASE_URI=

# ---- Supabase Storage (product photos live here, S3-compatible) ----
# Supabase → Project Settings → Storage → S3 Connection.
# Create a PUBLIC bucket named "product-images" first (Storage → New bucket → Public).
S3_BUCKET=product-images
S3_ENDPOINT=https://<project-ref>.storage.supabase.co/storage/v1/s3
S3_REGION=<region, e.g. eu-central-1>
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
